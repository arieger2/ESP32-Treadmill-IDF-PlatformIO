{
  "compilerOptions": {
    "target": "ES2015",
    "module": "amd",
    "outFile": "./build/workout-app.js",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": true,
    "lib": ["ES2015", "DOM"],
    "skipLibCheck": true
  },
  "include": [
    "typescript/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
